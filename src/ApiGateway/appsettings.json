{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "event-route": {
        "ClusterId": "event-cluster",
        "Match": {
          "Path": "/events/{**catch-all}"
        }
      },
      "garage-route": {
        "ClusterId": "garage-cluster",
        "Match": {
          "Path": "/garage/{**catch-all}"
        }
      },
      "maintenance-route": {
        "ClusterId": "maintenance-cluster",
        "Match": {
          "Path": "/maintenance/{**catch-all}"
        }
      },
      "club-route": {
        "ClusterId": "club-cluster",
        "Match": {
          "Path": "/clubs/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://identityservice:8080"
          }
        }
      },
      "event-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://eventservice:8080"
          }
        }
      },
      "garage-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://garageservice:8080"
          }
        }
      },
      "maintenance-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://maintenanceservice:8080"
          }
        }
      },
      "club-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://clubservice:8080"
          }
        }
      }
    }
  }
}